<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <!--
      Categorized, independently runnable pipelines. Each testsuite can be run in
      isolation with:  php artisan test [[testsuite]]=Name
      The System test dashboard (SuperAdmin) and CI run them in the sequence below.
      The broad "Feature" suite excludes the categorized subfolders so tests are
      never counted or executed twice.
    -->
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
            <exclude>tests/Feature/Smoke</exclude>
            <exclude>tests/Feature/Api</exclude>
            <exclude>tests/Feature/Notifications</exclude>
            <exclude>tests/Feature/Mail</exclude>
            <exclude>tests/Feature/Tenancy</exclude>
            <exclude>tests/Feature/Rbac</exclude>
        </testsuite>
        <testsuite name="Smoke">
            <directory>tests/Feature/Smoke</directory>
        </testsuite>
        <testsuite name="Api">
            <directory>tests/Feature/Api</directory>
        </testsuite>
        <testsuite name="Notifications">
            <directory>tests/Feature/Notifications</directory>
        </testsuite>
        <testsuite name="Mail">
            <directory>tests/Feature/Mail</directory>
        </testsuite>
        <testsuite name="Rbac">
            <directory>tests/Feature/Rbac</directory>
        </testsuite>
        <testsuite name="Tenancy">
            <directory>tests/Feature/Tenancy</directory>
        </testsuite>
        <testsuite name="Load">
            <directory>tests/Load</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_KEY" value="base64:QpqWBoNnyF/v8SmlRC/DzLq9d75hjncrv55mbjLWsVc="/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="CACHE_DRIVER" value="array"/>
        <env name="DB_CONNECTION" value="sqlite"/>
        <env name="DB_DATABASE" value=":memory:"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="MULTI_TENANT" value="false"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
    </php>
</phpunit>
